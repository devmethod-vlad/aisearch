COMPOSE_PATH_SEPARATOR=';'
COMPOSE_FILE='docker-compose.yml;docker-compose.prod.yml'

REQUIRED_CONTAINERS="aisearch-celery-search-worker aisearch-queue-worker"

LOGS_HOST_DIR=./logs
LOGS_CONTR_DIR=/usr/src/logs
LOGS_ACCESS_LOCATION=/app/access.log

CUDA_IMAGE=nvidia/cuda:12.8.0-devel-ubuntu22.04
CUDA_WHEEL=cu128
HTTPS_PROXY_ENV=''
HTTP_PROXY_ENV=''
IMAGE_NAME_BASE=cuda-python-uv-base:latest
IMAGE_NAME_DEPS=aisearch-deps-base:latest
IMAGE_NAME=aisearch-app-dev:latest
REGISTRY=localhost:5001

APP_MODE=dev
APP_HOST=0.0.0.0
APP_PORT=5155
APP_DEBUG_HOST=0.0.0.0
APP_DEBUG_PORT=5678
APP_WORKERS_NUM=2
APP_ACCESS_KEY=123
APP_PREFIX=

APP_LOGS_LOCATION=app/app.log
APP_LOG_LEVEL=INFO

# Нормализовать ли запрос
APP_NORMALIZE_QUERY=false
APP_COLLECTION_FILES_HOST_DIR=./collections
APP_COLLECTION_FILES_CONTR_DIR=/collections

APP_DATA_UNIQUE_ID=ext_id
APP_RECREATE_DATA=false
APP_GENERATE_PRELAUNCH_DATA=true
APP_PRELAUNCH_DATA_HOST_DIR=./prelaunch
APP_PRELAUNCH_DATA_CONTR_DIR=/prelaunch

# === CORS ===
# По умолчанию выключен, чтобы поведение backend без явной настройки не менялось.
# Включайте только для локального тестирования или явно доверенных frontend-origin.
APP_CORS_ENABLED=false

# Список разрешённых origin через запятую.
# Для локального Vite frontend обычно нужны:
# http://localhost:5173,http://127.0.0.1:5173
APP_CORS_ALLOW_ORIGINS=

# Regex для разрешённых origin. Обычно не нужен, можно оставить пустым.
APP_CORS_ALLOW_ORIGIN_REGEX=

# Методы, разрешённые для CORS-запросов.
APP_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Заголовки, разрешённые для CORS-запросов.
APP_CORS_ALLOW_HEADERS=*

# true нужно только если frontend отправляет cookie/credentials.
# Нельзя использовать вместе с APP_CORS_ALLOW_ORIGINS=*.
APP_CORS_ALLOW_CREDENTIALS=false

APP_MODELSTORE_HOST_PATH=./models
APP_MODELSTORE_CONTR_PATH=/usr/src/models

NLTK_DATA_HOST_PATH=./nltk
NLTK_DATA_CONTR_PATH=/srv/nltk_data

SLOWAPI_LIMIT_SEARCH=200/minute

# periodic
ETCD_AUTO_COMPACTION_MODE=revision
# time, like "1h"
ETCD_AUTO_COMPACTION_RETENTION=1000
ETCD_QUOTA_BACKEND_BYTES=4294967296
ETCD_SNAPSHOT_COUNT=50000
ETCD_HOST=aisearch-etcd
ETCD_PORT=2379
ETCD_VOLUME_HOST_PATH=./volumes/etcd
ETCD_VOLUME_CONTR_PATH=/etcd

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_HOST=aisearch-minio
MINIO_WEB_UI_PORT=9001
MINIO_BUCKET_NAME=aisearch-bucket
MINIO_PORT=9000
MINIO_VOLUME_HOST_PATH=./volumes/minio
MINIO_VOLUME_CONTR_PATH=/minio_data

MILVUS_HOST=aisearch-milvus
MILVUS_PORT=19530
MILVUS_USE_SSL=false
MILVUS_WEB_UI_PORT=9091
MILVUS_CONNECTION_TIMEOUT=120
MILVUS_QUERY_TIMEOUT=30
MILVUS_METRIC_TYPE=IP
MILVUS_COLLECTION_NAME=kb_default
MILVUS_VECTOR_FIELD=embedding
MILVUS_ID_FIELD=pk
MILVUS_SEARCH_FIELDS=question
MILVUS_OUTPUT_FIELDS=row_idx,source,ext_id,page_id,role,component,product,actual,second_line,question,question_md,analysis,analysis_md,answer,answer_md,answer_copy,for_user,jira,modified_at
MILVUS_VOLUME_HOST_PATH=./volumes/milvus
MILVUS_VOLUME_CONTR_PATH=/var/lib/milvus
MILVUS_MODEL_NAME=USER-bge-m3
MILVUS_SCHEMA_PATH=app/settings/conf.json

# === Очередь фоновых поисковых задач (legacy-префикс LLM_QUEUE_* для совместимости) ===
LLM_QUEUE_LIST_KEY=llm:queue:list
LLM_QUEUE_TICKET_HASH_PREFIX=llm:ticket:
LLM_QUEUE_MAX_SIZE=10
LLM_QUEUE_TICKET_TTL=3600
LLM_QUEUE_DRAIN_INTERVAL_SEC=1

# === Переключатели поиска ===
SEARCH_USE_OPENSEARCH=true
# Включает OpenSearch как lexical-ветку; при false работает только dense-ветка.
SEARCH_USE_BM25=false

# Top-K dense кандидатов для short-mode.
SHORT_DENSE_TOP_K=30
# Top-K lexical кандидатов для short-mode.
SHORT_LEX_TOP_K=20
# Финальное количество результатов для short-mode.
SHORT_TOP_K=5
# Вес dense score в short-mode (переопределяет HYBRID_W_DENSE, только если сработал SHORT_MODE).
SHORT_W_DENSE=0.3
# Вес lexical score в short-mode (переопределяет HYBRID_W_LEX, только если сработал SHORT_MODE).
SHORT_W_LEX=0.7
# Режим объединения dense/lex retrieval-кандидатов для short-mode:
# weighted_score — взвешенная сумма score_dense/score_lex;
# rrf — Reciprocal Rank Fusion по рангам dense/lex.
# Переопределяет HYBRID_FUSION_MODE только когда short-mode реально применился.
SHORT_FUSION_MODE=weighted_score
# Используется только при SHORT_FUSION_MODE=rrf.
# Переопределяет HYBRID_RRF_K только когда short-mode реально применился.
SHORT_RRF_K=60
# Вес dense ранга в RRF для short-mode (переопределяет HYBRID_RRF_W_DENSE только если сработал SHORT_MODE).
SHORT_RRF_W_DENSE=1.0
# Вес lexical ранга в RRF для short-mode (переопределяет HYBRID_RRF_W_LEX только если сработал SHORT_MODE).
SHORT_RRF_W_LEX=1.0

# Включает OpenSearch в short-mode (переопределяет SEARCH_USE_OPENSEARCH только если сработал SHORT_MODE).
SHORT_USE_OPENSEARCH=true
SHORT_MODE=true
# Порог длины запроса (в токенах/словах по внутренней логике), при котором применяется short-mode.
SHORT_MODE_LIMIT=3
# === Параметры гибридного склейщика ===
# Сколько dense-кандидатов сначала запрашивать из Milvus до precut/fusion/reranker.
# Чем больше значение, тем выше recall dense-ветки, но дороже последующая обработка.
HYBRID_DENSE_TOP_K=50
# Сколько lexical-кандидатов сначала запрашивать из OpenSearch до precut/fusion/reranker.
# Важно для точных совпадений, терминов, кодов и аббревиатур.
HYBRID_LEX_TOP_K=20
# Сколько финальных результатов вернуть после fusion и, если включён, reranker.
HYBRID_TOP_K=10
# Веса dense/lex на стадии retrieval fusion. Для RRF управляют вкладом рангов.
# 0.6 0.25 0.15
HYBRID_W_DENSE=0.55
HYBRID_W_LEX=0.15
# Режим объединения dense/lex retrieval-кандидатов:
# weighted_score — взвешенная сумма score_dense/score_lex;
# rrf — Reciprocal Rank Fusion по рангам dense/lex.
HYBRID_FUSION_MODE=weighted_score
# Параметр RRF. Используется только при HYBRID_FUSION_MODE=rrf.
HYBRID_RRF_K=60
# Используются только в fusion_mode=rrf (RRF rank contribution).
HYBRID_RRF_W_DENSE=1.0
HYBRID_RRF_W_LEX=1.0
# Режим финального ранжирования гибридного поиска.
# Допустимые значения:
# fusion_only:
#   Cross-encoder не запускается.
#   Итоговая сортировка идёт по score_fusion.
# ce_final:
#   Cross-encoder запускается.
#   Итоговая сортировка идёт по score_ce_raw.
#   score_fusion используется как tie-breaker.
#   HYBRID_FINAL_CE_SCORE не используется.
# ce_blend:
#   Cross-encoder запускается только если HYBRID_FINAL_W_CE > 0.
#   score_final = normalized fusion + normalized CE.
#   Используются HYBRID_FINAL_W_FUSION, HYBRID_FINAL_W_CE, HYBRID_FINAL_FUSION_NORM, HYBRID_FINAL_CE_SCORE.
# legacy_weighted:
#   Работает только с HYBRID_FUSION_MODE=weighted_score.
#   Сохраняет старую удачную формулу:
#   score_final = w_dense * score_dense_norm + w_lex * score_lex + final_w_ce * score_ce.
#   HYBRID_FINAL_W_CE заменяет старый CE-вес legacy режима.
HYBRID_FINAL_RANK_MODE=fusion_only
# Используется в ce_blend как вес score_fusion_norm.
HYBRID_FINAL_W_FUSION=1.0
# Используется:
# - в ce_blend как вес score_ce_norm
# - в legacy_weighted как вес score_ce
# Если 0:
# - CE не запускается в ce_blend и legacy_weighted
# - CE-вклад считается нулевым
HYBRID_FINAL_W_CE=0.0
# Используется только в ce_blend.
# Допустимые значения:
# - max
# - minmax
HYBRID_FINAL_FUSION_NORM=max
# Используется только в ce_blend.
# Допустимые значения:
# - processed
# - raw
# processed использует score_ce.
# raw использует score_ce_raw с minmax-нормализацией.
# ce_final всегда использует score_ce_raw и не смотрит на HYBRID_FINAL_CE_SCORE.
HYBRID_FINAL_CE_SCORE=processed

# Переопределяет HYBRID_FINAL_W_FUSION только если сработал SHORT_MODE.
SHORT_FINAL_W_FUSION=1.0
# Переопределяет HYBRID_FINAL_W_CE только если сработал SHORT_MODE.
SHORT_FINAL_W_CE=0.0
# Переопределяет HYBRID_FINAL_FUSION_NORM только если сработал SHORT_MODE.
SHORT_FINAL_FUSION_NORM=max
# Переопределяет HYBRID_FINAL_CE_SCORE только если сработал SHORT_MODE.
SHORT_FINAL_CE_SCORE=processed
HYBRID_CACHE_TTL=3600
# После изменения логики scoring/fusion/rerank увеличьте версию, чтобы не смешивать старый cache.
HYBRID_VERSION=v1
HYBRID_COLLECTION_NAME=kb_default
HYBRID_MERGE_BY_FIELD=ext_id
HYBRID_MERGE_FIELDS=row_idx,source,ext_id,page_id,role,component,product,actual,second_line,question,question_md,analysis,analysis_md,answer,answer_md,answer_copy,for_user,jira,modified_at
HYBRID_OUTPUT_FIELDS=row_idx,source,ext_id,page_id,role,component,product,actual,second_line,question,question_md,analysis,analysis_md,answer,answer_md,answer_copy,for_user,jira,modified_at
# Абсолютный нижний порог для dense score после преобразования в общую шкалу.
# Кандидаты ниже порога отсекаются, кроме гарантированного HYBRID_PRECUT_MIN_KEEP.
HYBRID_DENSE_ABS_MIN=0.25
# Относительный порог dense score от лучшего dense-кандидата: best_score * value.
# Чем выше значение, тем агрессивнее отсекается dense-хвост.
HYBRID_DENSE_REL_MIN=0.6
# Относительный порог lexical score от лучшего OpenSearch-кандидата после нормализации.
# Чем выше значение, тем агрессивнее отсекается lexical-хвост.
HYBRID_LEX_REL_MIN=0.5
# Минимум кандидатов, который нужно оставить в каждой ветке после precut,
# даже если абсолютные/относительные пороги оказались слишком строгими.
HYBRID_PRECUT_MIN_KEEP=3

HYBRID_INTERMEDIATE_RESULTS_TOP_K=5
# Runtime-параметры управления кешем/intermediate/presearch передаются в теле /hybrid-search/search

# === Token filters for multi-value metadata ===
TOKEN_FILTERS_ENV_SEPARATOR=,
TOKEN_FILTERS_RAW_FIELDS=role,product,component
TOKEN_FILTERS_TOKEN_SUFFIX=_tokens
TOKEN_FILTERS_RAW_SEPARATOR=;

# === OpenSearch ===
OS_HOST=aisearch-opensearch
OS_PORT=9200
OS_INDEX_NAME=aisearch-qa
OS_USE_SSL=false
OS_VERIFY_CERTS=false
OS_USER=
OS_PASSWORD=
# OS_QUERY_PROFILE=fast
# Поля, по которым OpenSearch выполняет lexical/BM25-поиск.
# Можно задавать boost через ^: question^4,analysis^2,answer^2
OS_SEARCH_FIELDS=question
OS_OUTPUT_FIELDS=row_idx,source,ext_id,page_id,role,component,product,actual,second_line,question,question_md,analysis,analysis_md,answer,answer_md,answer_copy,for_user,jira,modified_at
# Оператор multi_match для терминов пользовательского запроса.
# Допустимые значения:
# - or  — мягкий режим, документ может совпасть по части терминов
# - and — строгий режим, документ должен совпасть по всем термам
# По умолчанию: or
OS_OPERATOR=or
# Минимальное количество/доля терминов, которые должны совпасть в multi_match.
# Используется только когда OS_OPERATOR=or.
# При OS_OPERATOR=and параметр не прокидывается в запрос.
# Поддерживаемые форматы OpenSearch: 1, 2, 70%, 2<70%
# По умолчанию: 1
OS_MIN_SHOULD_MATCH=1
# Тип OpenSearch multi_match-запроса.
# Допустимые значения:
# - best_fields
# - most_fields
# - cross_fields
# - phrase
# - phrase_prefix
# - bool_prefix
# По умолчанию: best_fields
OS_MULTI_MATCH_TYPE=best_fields
# Fuzziness для multi_match. 0 — отключено.
OS_FUZZINESS=0
OS_USE_RESCORE=false
OS_INDEX_ANSWER=false
OS_BULK_CHUNK_SIZE=1000
OS_SCHEMA_PATH=app/settings/os_index.json
OS_VOLUME_HOST_PATH=./volumes/opensearch-data
OS_VOLUME_CONTR_PATH=/usr/share/opensearch/data

REDIS_HOSTNAME=redis
REDIS_PORT=6379
REDIS_DATABASE=7

REDISINSIGHT_PORT=6399

CELERY_LOGS_LOCATION=/celery/celery.log
CELERY_LOG_LEVEL=INFO
CELERY_LOGS_QUEUE_LOCATION=/queue/queue.log
CELERY_LOG_QUEUE_LEVEL=INFO
CELERY_WORKERS_NUM=1
CELERY_GRACE_PERIOD_SECONDS=30

# === Глобальный семафор поисковых задач (legacy-префикс LLM_GLOBAL_SEM_* для совместимости) ===
LLM_GLOBAL_SEM_REDIS_DSN="redis://${REDIS_HOSTNAME}:${REDIS_PORT}/${REDIS_DATABASE}"
LLM_GLOBAL_SEM_KEY=llm:{global}:sem
LLM_GLOBAL_SEM_LIMIT=2
LLM_GLOBAL_SEM_TTL_MS=120000
LLM_GLOBAL_SEM_WAIT_TIMEOUT_MS=30000
LLM_GLOBAL_SEM_HEARTBEAT_MS=30000

# === CrossEncoder (reranker) ===
# или cuda
RERANKER_DEVICE=cuda
RERANKER_BATCH_SIZE=54
RERANKER_MAX_LENGTH=512
RERANKER_DTYPE=fp16
# RERANKER_SCORE_MODE влияет на score_ce (processed score).
# В CE-final режимах финальная сортировка идет по score_ce_raw, если он есть, иначе по score_ce.
# В legacy weighted-score режиме используется score_ce (а не score_ce_raw).
RERANKER_SCORE_MODE=sigmoid
RERANKER_SOFTMAX_TEMP=0.7
RERANKER_MODEL_NAME=cross-encoder-russian-msmarco
# Старый формат: CSV-список полей кандидата без подписей.
# Пример: question,analysis,answer
# Новый формат: объект field->label для формирования строк вида
# Вопрос: ...
# Анализ: ...
# Ответ: ...
# Пример: {"question":"Вопрос","analysis":"Анализ","answer":"Ответ"}
RERANKER_PAIRS_FIELDS=question

# === Прогрев эмбеддера/реранкера при старте ===
WARMUP_ENABLED=true
WARMUP_CE_PAIRS="Как оформить доступ в систему?||Как оформить доступ врача в систему?;Запись к врачу||Как записаться к врачу"
WARMUP_EMBED_TEXTS="Пример вопроса один;Пример вопроса два"

# включить логгирование времени
TIMEIT_LOG_METRICS_ENABLED=true
# Метрики в response включаются runtime-параметром metrics_enable в /hybrid-search/search

NLTK_DATA=./nltk

EXTRACT_EDU_EMIAS_URL="https://edu.example.com"
#EXTRACT_EDU_EMIAS_TOKEN=
EXTRACT_EDU_EMIAS_ATTACHMENTS_PAGE_ID=191032284
EXTRACT_KNOWLEDGE_BASE_FILE_NAME="KB_wiki.xlsx"
EXTRACT_VIO_BASE_FILE_NAME="Вопросы_и_ответы.xlsx"
EXTRACT_CRON_UPDATE_TIMES="21:05"
EXTRACT_EDU_TIMEOUT=20
EXTRACT_BASE_HARVESTER_API_URL="https://https://edu.example.com/edu-rest-api/test/data-harvester"
EXTRACT_KB_HARVESTER_SUFFIX="/knowledge-base/collect-all"
EXTRACT_VIO_HARVESTER_SUFFIX="/vio/runtime_harvest"
EXTRACT_LOGS_LOCATION=/updater/updater.log
EXTRACT_LOG_LEVEL=INFO

# === Export deduplicated updater data to Confluence ===
EXTRACT_DEDUPLICATED_EXCEL_UPLOAD_ENABLED=false
EXTRACT_DEDUPLICATED_EXCEL_FILE_NAME_TEMPLATE=statistic_{timestamp}.xlsx
EXTRACT_DEDUPLICATED_EXCEL_KEEP_VERSIONS=5
EXTRACT_DEDUPLICATED_EXCEL_MAX_RETRIES=5
EXTRACT_DEDUPLICATED_EXCEL_RETRY_BACKOFF_BASE_SECONDS=1
EXTRACT_DEDUPLICATED_EXCEL_RETRY_BACKOFF_MAX_SECONDS=30

# === Glossary sync ===
GLOSSARY_API_URL="https://edu.emias.ru/edu-rest-api/test/glossary/glossary/getelements"
GLOSSARY_PAGE_LIMIT=500
GLOSSARY_CRON_UPDATE_TIMES="03:30"
GLOSSARY_REQUEST_TIMEOUT=30
GLOSSARY_MAX_RETRIES=5
GLOSSARY_RETRY_BACKOFF_BASE_SECONDS=1
GLOSSARY_RETRY_BACKOFF_MAX_SECONDS=30
GLOSSARY_ABBREVIATION_DELIMITER=";"
GLOSSARY_TERM_DELIMITER=";"

# === PosgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=postgresdb
POSTGRES_PORT=5432
POSTGRES_DB=aisearch
POSTGRES_VOLUME_HOST_PATH=./volumes/pgdata
POSTGRES_VOLUME_CONTR_PATH=/var/lib/postgresql/data

PGADMIN_DEFAULT_EMAIL=pgadmin@example.com
#PGADMIN_DEFAULT_PASSWORD=
PGADMIN_PORT=5050
